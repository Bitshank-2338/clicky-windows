# ============================================================
# Clicky for Windows — API Keys (all optional, auto-detected)
# ============================================================
# Copy this file to .env and fill in the keys you have.
# Clicky auto-detects what's available and uses the best one.
# If no keys are set, it falls back to Ollama (free, local).

# ── LLM Providers (priority: Claude > OpenAI > Gemini > Ollama) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Any OpenAI-compatible server works via the OpenAI provider — set the base
# URL + a default model, put the provider's key in OPENAI_API_KEY. Examples:
#   DeepSeek:   OPENAI_BASE_URL=https://api.deepseek.com   OPENAI_DEFAULT_MODEL=deepseek-chat
#   DashScope:  OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=

# ── Speech-to-Text ───────────────────────────────────────────
# Leave empty to use faster-whisper (free, local, runs on CPU)
DEEPGRAM_API_KEY=
# OPENAI_API_KEY also enables OpenAI Whisper if set above

# ── Text-to-Speech ───────────────────────────────────────────
# Leave empty to use edge-tts (free, no key, Microsoft neural)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Web Search (for grounding LLM with live info) ────────────
# Leave empty to use DuckDuckGo (free, no key)
TAVILY_API_KEY=

# ── Ollama Settings ──────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Legacy single-model knob (used as fallback if the two below are empty)
OLLAMA_MODEL=llama3.2-vision
# Per-task model selection — vision = screen-aware, text = Code Mode / journal Q&A.
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_TEXT_MODEL=qwen2.5vl:7b

# ── LM Studio Settings ───────────────────────────────────────
# Alternative to Ollama. Start LM Studio → Developer tab → Start Server,
# load a model, then select "lmstudio" from Tray → Model. No key needed.
LMSTUDIO_HOST=http://localhost:1234/v1
# Leave empty to use whatever model is currently loaded in LM Studio.
LMSTUDIO_MODEL=

# ── App Settings ─────────────────────────────────────────────
# Hotkey to activate push-to-talk (default: ctrl+alt+space)
CLICKY_HOTKEY=ctrl+alt+space
# Whisper model size: tiny, base, small, medium (larger = slower but more accurate)
WHISPER_MODEL=base

# Which LLM to use on startup: claude, openai, gemini, ollama, lmstudio
CLICKY_ACTIVE_LLM=lmstudio
