# ============================================================
# Clicky for Windows — API Keys (all optional, auto-detected)
# ============================================================
# Copy this file to .env and fill in the keys you have.
# Clicky auto-detects what's available and uses the best one.
# If no keys are set, it falls back to Ollama (free, local).

# ── LLM Providers (priority: Claude > OpenAI > Gemini > Ollama) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Speech-to-Text ───────────────────────────────────────────
# Leave empty to use faster-whisper (free, local, runs on CPU)
DEEPGRAM_API_KEY=
# OPENAI_API_KEY also enables OpenAI Whisper if set above

# ── Text-to-Speech ───────────────────────────────────────────
# Leave empty to use edge-tts (free, no key, Microsoft neural)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Web Search (for grounding LLM with live info) ────────────
# Leave empty to use DuckDuckGo (free, no key)
TAVILY_API_KEY=

# ── Ollama Settings ──────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision

# ── App Settings ─────────────────────────────────────────────
# Hotkey to activate push-to-talk (default: ctrl+alt+space)
CLICKY_HOTKEY=ctrl+alt+space
# Whisper model size: tiny, base, small, medium (larger = slower but more accurate)
WHISPER_MODEL=base
